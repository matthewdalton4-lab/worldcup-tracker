# API-Football credentials (https://www.api-football.com/)
# Add these to your Netlify environment variables — never commit the real values.
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# WC 2026 league/season identifiers on API-Football
# Confirm the correct league ID once the tournament is live
WC_LEAGUE_ID=1
WC_SEASON=2026
